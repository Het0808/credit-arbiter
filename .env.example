# Copy to .env and fill in. All values have safe defaults except secrets.

# --- Core ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# SQLite (default, local dev):
DATABASE_URL=sqlite:///./local_dev.db
# PostgreSQL (production; matches docker-compose):
# DATABASE_URL=postgresql+psycopg://halcyon:halcyon@localhost:5432/halcyon

# --- Risk scoring ---
# rule | ml   (ml uses the trained model; needs requirements-ml.txt + the model file)
RISK_SCORER=ml

# --- Policy retrieval (RAG) ---
# tfidf | vector   (vector uses Qdrant + embeddings; needs requirements-rag.txt)
RETRIEVER=vector
# Qdrant: leave unset/":memory:" for embedded, or point at a server:
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=halcyon_policies
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VECTOR_SCORE_FLOOR=0.35

# --- LLM explanation (FR-9, via OpenRouter) ---
# none | openrouter   (openrouter needs requirements-llm.txt + the key below)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...your-key...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
