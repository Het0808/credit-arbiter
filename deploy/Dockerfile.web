# Frontend image: build the Vite app, serve it via nginx, proxy /api to the api service.
FROM node:22-alpine AS build
WORKDIR /ui
COPY ui/package.json ui/package-lock.json* ./
RUN npm install
COPY ui/ ./
# API_BASE auto-selects same-origin /api when not on localhost (see main.js).
RUN npm run build

FROM nginx:alpine
COPY --from=build /ui/dist /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
