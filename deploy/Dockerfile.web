# Frontend image: build the Vite app, serve it via nginx, proxy /api to the api service.
FROM node:22-alpine AS build
WORKDIR /ui
COPY ui/package.json ui/package-lock.json* ./
RUN npm install
COPY ui/ ./
# Point the frontend at same-origin /api (nginx proxies it to the api container).
RUN sed -i "s#http://localhost:8000/api#/api#" main.js && npm run build

FROM nginx:alpine
COPY --from=build /ui/dist /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
